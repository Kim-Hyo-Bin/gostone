# Example gostone configuration (INI, Keystone/oslo.config style).
# Copy to /etc/gostone/gostone.conf or pass: gostone --config-file /path/to/gostone.conf
#
# Drop-in fragments: place additional *.conf files in /etc/gostone/gostone.conf.d/
# or set --config-dir /path/to/dir (or GOSTONE_CONFIG_DIR).

[DEFAULT]
# If true, Gin runs in debug mode when GIN_MODE is unset.
debug = false

[database]
# Same role as Keystone [database] connection: SQLAlchemy URL or native driver DSN.
#
# SQLite (in-process, dev / tests; glebarez, no CGO):
#   connection = file::memory:?cache=shared
#   connection = file:/var/lib/gostone/gostone.db
# SQLAlchemy-style (recommended when mirroring Keystone):
#   connection = mysql+pymysql://keystone:PASSWORD@127.0.0.1:3306/keystone
#   connection = postgresql+psycopg2://keystone:PASSWORD@127.0.0.1:5432/keystone
# Native Go DSNs:
#   connection = user:pass@tcp(127.0.0.1:3306)/keystone?parseTime=true&charset=utf8mb4
#   connection = postgres://user:pass@127.0.0.1:5432/keystone?sslmode=disable
#   connection = host=127.0.0.1 user=keystone password=SECRET dbname=keystone sslmode=disable
connection = file::memory:?cache=shared

[service]
# HTTP listen address (host:port or :port). Keystone public API defaults to 5000.
listen = :5000
# Public URL for service catalog + bootstrap (scheme://host:port). Override with GOSTONE_PUBLIC_URL.
# public_url = http://controller:5000

[token]
# uuid = opaque DB-backed tokens (default; closest to Keystone UUID provider).
# jwt = signed JWT (dev/tests). fernet = Keystone-style Fernet (requires [fernet_tokens]).
provider = uuid
# Required when provider = jwt. Ignored for uuid / fernet.
secret = change-me-in-production
# Token lifetime in hours.
expiration_hours = 24

[auth]
# Comma-separated method order (Fernet payload bit order). Override: GOSTONE_AUTH_METHODS
# methods = password, token

[fernet_tokens]
# Directory of numbered key files (0, 1, 2, …) like Keystone. Override: GOSTONE_FERNET_KEY_REPO
# key_repository = /etc/gostone/fernet-keys

[policy]
# Optional JSON map of action → rule expression; merged over built-in defaults. Override: GOSTONE_POLICY_FILE
# file = /etc/gostone/policy.json
